rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: documents
    // Document ID: {docId}
    // Fields:
    //   - id: string (required) - unique ID
    //   - name: string (required) - file name
    //   - type: string (required) - document category
    //   - numPages: number (required) - total pages
    //   - annotations: list (required) - list of annotation objects
    //   - pdfUrl: string (required) - link to storage
    //   - ownerId: string (required) - user UID
    //   - createdAt: timestamp (required) - creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "antonellaschiavoni2@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['id', 'name', 'type', 'numPages', 'annotations', 'pdfUrl', 'ownerId', 'createdAt']) &&
             data.id is string &&
             data.name is string && data.name.size() < 255 &&
             data.type is string &&
             data.numPages is int &&
             data.annotations is list &&
             data.pdfUrl is string &&
             data.ownerId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /documents/{docId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isAuthenticated() && isValidDocument(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidDocument(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
